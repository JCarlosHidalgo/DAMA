<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PackageId>DAMA.Software.MySqlUnitOfWork</PackageId>
    <Version>2.0.0</Version>
    <Author>Juan Carlos Hidalgo Sosa</Author>
    <Authors>Juan Carlos Hidalgo Sosa</Authors>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <Product>MySqlUnitOfWork</Product>
    <Description>Unit-of-work abstraction over a scoped MySQL connection for the DAMA backend services. Hides MySqlTransaction behind ITransactionContext so service and DAO interfaces stay free of MySql.Data.</Description>
    <Copyright>CC BY-SA 4.0, 2026</Copyright>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageTags>UnitOfWork,Transaction,MySQL,DAMA</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="JuanCarlosHS.SQLDaosPackage" Version="3.1.1" />
    <PackageReference Include="MySql.Data" Version="9.3.0" />
  </ItemGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>
