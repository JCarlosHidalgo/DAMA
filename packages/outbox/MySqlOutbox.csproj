<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PackageId>DAMA.Software.MySqlOutbox</PackageId>
    <Version>2.0.0</Version>
    <Author>Juan Carlos Hidalgo Sosa</Author>
    <Authors>Juan Carlos Hidalgo Sosa</Authors>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <Product>MySqlOutbox</Product>
    <Description>Lease + failure-recording helpers for the transactional Outbox pattern on MySQL. Shared between DAMA backend services that publish events via outbox tables.</Description>
    <Copyright>CC BY-SA 4.0, 2026</Copyright>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageTags>Outbox,MySQL,Messaging,DAMA</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="DAMA.Software.MySqlUnitOfWork" Version="2.0.0" />
    <PackageReference Include="JuanCarlosHS.SQLDaosPackage" Version="3.1.1" />
    <PackageReference Include="MySql.Data" Version="9.3.0" />
  </ItemGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>
