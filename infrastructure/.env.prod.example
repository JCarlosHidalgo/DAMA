# Template for the production deployment on Dokploy (compose.prod.yaml).
# Load these into the Dokploy "Environment" editor for the Compose service — Dokploy
# writes them to a .env next to the compose and compose.prod.yaml reads them via ${VAR}.
# A real infrastructure/.env.prod stays gitignored if you ever run the prod compose by hand.
# DO NOT reuse the values from .env.dev or .env.staging — production must have its own keys.
# Treat this file as a secret-bearing document at rest. See infrastructure/SECRETS.md.
#
# Ingress is handled by Dokploy domains (Traefik) → there are NO host port variables here;
# compose.prod.yaml uses `expose`, not `ports`. Map domains in the Dokploy UI:
#   dama-software.org      → service `frontend`    container port 80
#   api.dama-software.org  → service `api-gateway` container port 80
#
# Generate the JWT pair fresh on the prod host (do NOT mail base64'd keys around):
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out priv.pem
#   openssl rsa -in priv.pem -pubout -out pub.pem
#   base64 -w0 priv.pem    # JWT_PRIVATE_KEY_B64
#   base64 -w0 pub.pem     # JWT_PUBLIC_KEY_B64
# Generate the callback secret fresh:
#   openssl rand -base64 64 | tr -d '\n=' | tr '+/' '-_'

# Absolute path of the repo checkout on the Dokploy host (build context for compose.prod.yaml).
CONTEXT=/absolute/path/to/DAMA

# In production the four MySQL are Dokploy-managed Database resources (so Dokploy
# can run native mysqldump→S3 backups), NOT compose containers. There are therefore
# no *_DB_PASSWORD / *_DB_SCHEMA here (those only feed the dev mysql:9 containers).
# Each backend gets its full connection string via DB_CONNECTION_STRING. Point `server`
# at the Dokploy database's internal host and fill the prod credentials.
AUTH_DB_CONNECTION_STRING=server=__dokploy_auth_db_host__;port=3306;uid=__user__;pwd=__set_strong_password__;database=Auth;Allow User Variables=True;Max Pool Size=300;Min Pool Size=10
COURSE_MANAGEMENT_DB_CONNECTION_STRING=server=__dokploy_course_management_db_host__;port=3306;uid=__user__;pwd=__set_strong_password__;database=CourseManagement;Allow User Variables=True;Max Pool Size=300;Min Pool Size=10
ATTENDANCE_DB_CONNECTION_STRING=server=__dokploy_attendance_db_host__;port=3306;uid=__user__;pwd=__set_strong_password__;database=Attendance;Allow User Variables=True;Max Pool Size=300;Min Pool Size=10
PAYMENT_DB_CONNECTION_STRING=server=__dokploy_payment_db_host__;port=3306;uid=__user__;pwd=__set_strong_password__;database=Payment;Allow User Variables=True;Max Pool Size=300;Min Pool Size=10

TODOTIX_APPKEY=__set_from_todotix_panel_prod_app__
TODOTIX_CALLBACK_URL=https://api.dama-software.org/api/payment/qr/callback

PAYMENT_CALLBACK_SECRET=__prod_unique_64_bytes__

JWT_ISSUER=DAMA_Software
JWT_PRIVATE_KEY_B64=__prod_unique_priv_pem_b64__
JWT_PUBLIC_KEY_B64=__prod_unique_pub_pem_b64__

RABBITMQ_USER=dama
RABBITMQ_PASSWORD=__set_strong_password__
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672

# DbGate — schema admin behind the gateway at https://api.dama-software.org/api/db-gate/.
# It can reach and edit all four prod databases, so use strong, unique credentials.
# The four connections are added once in the DbGate UI and persist in the dbgate-data volume.
DBGATE_LOGIN=admin
DBGATE_PASSWORD=__set_strong_password__
