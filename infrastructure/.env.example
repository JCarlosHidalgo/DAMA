# Copy to infrastructure/.env.dev and fill in. The real .env.dev is gitignored.
#
# Generate JWT_TOKEN / PAYMENT_CALLBACK_SECRET locally with:
#   openssl rand -base64 64 | tr -d '\n=' | tr '+/' '-_'
# They MUST be different values (a leak of one must not compromise the other).

# Absolute path of this repo on the host. Compose uses it for build context and bind mounts.
# Auto-set by `compose-up.sh` (it bootstraps from the repo root the first time it runs,
# and warns if this value diverges from the current repo). Only edit by hand when
# running compose from outside the repo.
CONTEXT=/absolute/path/to/DAMA

# Host-published ports. Dev is offset by +100 from prod so the dev stack can run
# alongside the prod ports on the same host (prod uses 8000/8001/15672).
API_GATEWAY_HOST_PORT=8100
FRONTEND_HOST_PORT=8101
RABBITMQ_MANAGEMENT_HOST_PORT=15772

# Per-service MySQL passwords. Dev defaults (`admin`) are fine because the DB containers
# are only reachable inside the compose network. Rotate for any non-local deployment.
AUTH_DB_PASSWORD=admin
AUTH_DB_SCHEMA=Auth

COURSE_MANAGEMENT_DB_PASSWORD=admin
COURSE_MANAGEMENT_DB_SCHEMA=CourseManagement

ATTENDANCE_DB_PASSWORD=admin
ATTENDANCE_DB_SCHEMA=Attendance

PAYMENT_DB_PASSWORD=admin
PAYMENT_DB_SCHEMA=Payment

# Connection string injected into each backend container (read as DB_CONNECTION_STRING).
# Dev hosts are the compose service names. The password is duplicated here and in
# *_DB_PASSWORD above (the mysql:9 container needs the discrete value); keep them in sync.
AUTH_DB_CONNECTION_STRING=server=AuthDB;port=3306;uid=root;pwd=admin;database=Auth;Allow User Variables=True;Max Pool Size=300;Min Pool Size=10
COURSE_MANAGEMENT_DB_CONNECTION_STRING=server=CourseManagementDB;port=3306;uid=root;pwd=admin;database=CourseManagement;Allow User Variables=True;Max Pool Size=300;Min Pool Size=10
ATTENDANCE_DB_CONNECTION_STRING=server=AttendanceDB;port=3306;uid=root;pwd=admin;database=Attendance;Allow User Variables=True;Max Pool Size=300;Min Pool Size=10
PAYMENT_DB_CONNECTION_STRING=server=PaymentDB;port=3306;uid=root;pwd=admin;database=Payment;Allow User Variables=True;Max Pool Size=300;Min Pool Size=10

# Issued by Todotix; rotate from their merchant panel, not here.
TODOTIX_APPKEY=__set_in_todotix_panel__
TODOTIX_CALLBACK_URL=https://api.dama-software.org/api/Payment/qr/callback

# HMAC-SHA256 key used by Payment to sign the `sig` query param on the Todotix
# callback URL and by Attendance to authenticate the gRPC callback metadata.
PAYMENT_CALLBACK_SECRET=__generate_random_64_bytes__

# Asymmetric JWT signing keys. Auth holds the private key and signs every
# token; the other backends only carry the public key and validate. A leak of
# any non-Auth service therefore cannot mint tokens.
#
# Generate locally with:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out priv.pem
#   openssl rsa -in priv.pem -pubout -out pub.pem
#   base64 -w0 priv.pem    # JWT_PRIVATE_KEY_B64
#   base64 -w0 pub.pem     # JWT_PUBLIC_KEY_B64
#
# Per-service audiences (`Auth`, `Payment`, `Attendance`, `CourseManagement`,
# `Credentials`) are hardcoded in compose.dev.yaml; Auth issues tokens whose `aud`
# claim lists all five so a single token covers the whole stack.
JWT_ISSUER=DAMA_Software
JWT_PRIVATE_KEY_B64=__base64_of_priv_pem__
JWT_PUBLIC_KEY_B64=__base64_of_pub_pem__

# RabbitMQ broker for the outbox/event pipeline. Reachable as `rabbitmq:5672`
# inside the compose network; AMQP port is not exposed to the host.
RABBITMQ_USER=dama
RABBITMQ_PASSWORD=dama
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
