# Copy to infrastructure/.env.dev and fill in. The real .env.dev is gitignored.
#
# Generate JWT_TOKEN / PAYMENT_CALLBACK_SECRET locally with:
#   openssl rand -base64 64 | tr -d '\n=' | tr '+/' '-_'
# They MUST be different values (a leak of one must not compromise the other).

# Absolute path of this repo on the host. Compose uses it for build context and bind mounts.
# Auto-set by `compose-up.sh` (it bootstraps from the repo root the first time it runs,
# and warns if this value diverges from the current repo). Only edit by hand when
# running compose from outside the repo.
CONTEXT=/absolute/path/to/DAMA

# Host-published ports. Dev is offset by +100 from prod so the dev stack can run
# alongside the prod ports on the same host (prod uses 8000/8001/15672).
API_GATEWAY_HOST_PORT=8100
FRONTEND_HOST_PORT=8101
RABBITMQ_MANAGEMENT_HOST_PORT=15772

# Per-environment published URLs. FRONTEND_API_BASE_URL is baked into the Angular
# bundle at build time (frontend Dockerfile build-arg API_BASE_URL); GATEWAY_FRONTEND_ORIGIN
# is the CORS-allowed frontend origin substituted into the gateway nginx.conf at start.
FRONTEND_API_BASE_URL=https://api-dev.dama-software.org
GATEWAY_FRONTEND_ORIGIN=https://dev.dama-software.org

# CSP hash (build-arg CSP_INLINE_SCRIPT_HASH) authorizing the inline no-FOUC theme
# script in apps/Frontend/src/index.html under script-src. Same value across all
# environments (derived from the committed index.html, not per-environment). Regenerate
# whenever that inline <script> changes — the browser's CSP error reports the value, or:
#   python3 -c "import base64,hashlib,re;b=re.search(r'<script>(.*?)</script>',open('apps/Frontend/src/index.html').read(),re.S).group(1);print('sha256-'+base64.b64encode(hashlib.sha256(b.encode()).digest()).decode())"
FRONTEND_CSP_INLINE_SCRIPT_HASH=sha256-sNze9CN4PWKrZeHWCxM9MpG6dtKlFTAb3qC8TlPTtSQ=

# Container hostnames per backend (app and DB). Defaults match the compose
# container_name values. Dokploy appends an identifier to container names in prod,
# so set these to the real assigned names there: the connection strings, gateway
# upstreams, the Attendance->CourseManagement gRPC URL and the TLS cert SAN all
# derive from them, so a rename only needs editing here.
AUTH_HOST_NAME=AuthService
COURSE_MANAGEMENT_HOST_NAME=CourseManagementService
ATTENDANCE_HOST_NAME=AttendanceService
PAYMENT_HOST_NAME=PaymentService
CREDENTIALS_HOST_NAME=CredentialsService

# DB hostnames. Dev defaults are the mysql container names; in prod (Dokploy-managed
# databases) set these to the managed DB hosts.
AUTH_DB_HOST_NAME=AuthDB
COURSE_MANAGEMENT_DB_HOST_NAME=CourseManagementDB
ATTENDANCE_DB_HOST_NAME=AttendanceDB
PAYMENT_DB_HOST_NAME=PaymentDB

# Per-service MySQL passwords. Dev defaults (`admin`) are fine because the DB containers
# are only reachable inside the compose network. Rotate for any non-local deployment.
AUTH_DB_PASSWORD=admin
AUTH_DB_SCHEMA=Auth

COURSE_MANAGEMENT_DB_PASSWORD=admin
COURSE_MANAGEMENT_DB_SCHEMA=CourseManagement

ATTENDANCE_DB_PASSWORD=admin
ATTENDANCE_DB_SCHEMA=Attendance

PAYMENT_DB_PASSWORD=admin
PAYMENT_DB_SCHEMA=Payment

# Connection string injected into each backend container (read as DB_CONNECTION_STRING).
# Host, password and schema are single-sourced from *_DB_HOST_NAME / *_DB_PASSWORD /
# *_DB_SCHEMA above and interpolated in here, so edit those once and the connection
# string follows (compose resolves ${VAR} against this env file). The *_DB_HOST_NAME
# lines must stay above these, since env-file interpolation only sees earlier vars.
AUTH_DB_CONNECTION_STRING=server=${AUTH_DB_HOST_NAME};port=3306;uid=root;pwd=${AUTH_DB_PASSWORD};database=${AUTH_DB_SCHEMA};Allow User Variables=True;Max Pool Size=300;Min Pool Size=10
COURSE_MANAGEMENT_DB_CONNECTION_STRING=server=${COURSE_MANAGEMENT_DB_HOST_NAME};port=3306;uid=root;pwd=${COURSE_MANAGEMENT_DB_PASSWORD};database=${COURSE_MANAGEMENT_DB_SCHEMA};Allow User Variables=True;Max Pool Size=300;Min Pool Size=10
ATTENDANCE_DB_CONNECTION_STRING=server=${ATTENDANCE_DB_HOST_NAME};port=3306;uid=root;pwd=${ATTENDANCE_DB_PASSWORD};database=${ATTENDANCE_DB_SCHEMA};Allow User Variables=True;Max Pool Size=300;Min Pool Size=10
PAYMENT_DB_CONNECTION_STRING=server=${PAYMENT_DB_HOST_NAME};port=3306;uid=root;pwd=${PAYMENT_DB_PASSWORD};database=${PAYMENT_DB_SCHEMA};Allow User Variables=True;Max Pool Size=300;Min Pool Size=10

# Todotix payment provider. BASE_URL is the API host (same in dev/prod; override if
# Todotix gives you a sandbox host). APPKEY is issued by Todotix — rotate from their panel.
# It is the global fallback app-key (used when a tenant has no own credential) AND the
# account that collects tenant subscription payments.
TODOTIX_BASE_URL=https://api.todotix.com
TODOTIX_APPKEY=__set_in_todotix_panel__
TODOTIX_CALLBACK_URL=https://api-dev.dama-software.org/api/payment/qr/callback

# ISO 4217 currency stamped on every Payment money record (debts, plans, ledgers).
# Both are OPTIONAL — Payment defaults to BOB / [BOB] when unset, validates the codes
# at startup (3 uppercase letters, DEFAULT must be within ALLOWED), and rejects an
# invalid config fail-fast. ALLOWED is a comma-separated list. To take effect in a
# container they must also be added to the Payment service `environment:` block.
PAYMENT_CURRENCY_DEFAULT=BOB
PAYMENT_CURRENCY_ALLOWED=BOB

# Base64-encoded 32-byte AES key used to encrypt each tenant's Todotix app-key at
# rest in the Payment DB. Generate with: openssl rand -base64 32
TODOTIX_APPKEY_ENCRYPTION_KEY=__base64_32_byte_key__

# HMAC-SHA256 key used by Payment to sign the `sig` query param on the Todotix
# callback URL and by Attendance to authenticate the gRPC callback metadata.
PAYMENT_CALLBACK_SECRET=__generate_random_64_bytes__

# Shared secret authenticating the synchronous Payment -> Auth gRPC call that
# applies a tenant's new subscription level + expiry the moment a subscription
# payment is captured. Payment sends it in gRPC metadata (x-subscription-secret);
# Auth validates it. Injected into both Auth and Payment. Generate random 64 bytes.
SUBSCRIPTION_GRPC_SECRET=__generate_random_64_bytes__

# Asymmetric JWT signing keys. Auth holds the private key and signs every
# token; the other backends only carry the public key and validate. A leak of
# any non-Auth service therefore cannot mint tokens.
#
# Generate locally with:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out priv.pem
#   openssl rsa -in priv.pem -pubout -out pub.pem
#   base64 -w0 priv.pem    # JWT_PRIVATE_KEY_B64
#   base64 -w0 pub.pem     # JWT_PUBLIC_KEY_B64
#
# Per-service audiences (`Auth`, `Payment`, `Attendance`, `CourseManagement`,
# `Credentials`) are hardcoded in compose.dev.yaml; Auth issues tokens whose `aud`
# claim lists all five so a single token covers the whole stack.
JWT_ISSUER=DAMA_Software
JWT_PRIVATE_KEY_B64=__base64_of_priv_pem__
JWT_PUBLIC_KEY_B64=__base64_of_pub_pem__

# RabbitMQ broker for the outbox/event pipeline. Reachable as `rabbitmq:5672`
# inside the compose network; AMQP port is not exposed to the host.
RABBITMQ_USER=dama
RABBITMQ_PASSWORD=dama
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
