# Template for a staging deployment. Copy to infrastructure/.env.staging and fill in.
# DO NOT reuse the values from .env (dev) — staging must have its own keys so a dev
# secret leak does not let anyone forge staging tokens. See infrastructure/SECRETS.md.
#
# Generate the JWT pair fresh:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out priv.pem
#   openssl rsa -in priv.pem -pubout -out pub.pem
#   base64 -w0 priv.pem    # JWT_PRIVATE_KEY_B64
#   base64 -w0 pub.pem     # JWT_PUBLIC_KEY_B64
# Generate the callback secret fresh:
#   openssl rand -base64 64 | tr -d '\n=' | tr '+/' '-_'

CONTEXT=/absolute/path/to/DAMA

# Host-published ports (canonical, like prod; dev is offset +100).
API_GATEWAY_HOST_PORT=8000
FRONTEND_HOST_PORT=8001
RABBITMQ_MANAGEMENT_HOST_PORT=15672

AUTH_DB_PASSWORD=__set_strong_password__
AUTH_DB_SCHEMA=Auth
COURSE_MANAGEMENT_DB_PASSWORD=__set_strong_password__
COURSE_MANAGEMENT_DB_SCHEMA=CourseManagement
ATTENDANCE_DB_PASSWORD=__set_strong_password__
ATTENDANCE_DB_SCHEMA=Attendance
PAYMENT_DB_PASSWORD=__set_strong_password__
PAYMENT_DB_SCHEMA=Payment

# Connection string injected into each backend container (read as DB_CONNECTION_STRING).
# If staging keeps its own MySQL, `server` is the DB host/service name and the password
# must match *_DB_PASSWORD above. If staging uses managed DBs, point `server` at them.
AUTH_DB_CONNECTION_STRING=server=__auth_db_host__;port=3306;uid=root;pwd=__set_strong_password__;database=Auth;Allow User Variables=True;Max Pool Size=300;Min Pool Size=10
COURSE_MANAGEMENT_DB_CONNECTION_STRING=server=__course_management_db_host__;port=3306;uid=root;pwd=__set_strong_password__;database=CourseManagement;Allow User Variables=True;Max Pool Size=300;Min Pool Size=10
ATTENDANCE_DB_CONNECTION_STRING=server=__attendance_db_host__;port=3306;uid=root;pwd=__set_strong_password__;database=Attendance;Allow User Variables=True;Max Pool Size=300;Min Pool Size=10
PAYMENT_DB_CONNECTION_STRING=server=__payment_db_host__;port=3306;uid=root;pwd=__set_strong_password__;database=Payment;Allow User Variables=True;Max Pool Size=300;Min Pool Size=10

TODOTIX_APPKEY=__set_from_todotix_panel_staging_app__
TODOTIX_CALLBACK_URL=https://staging.api.dama-software.org/api/payment/qr/callback

PAYMENT_CALLBACK_SECRET=__staging_unique_64_bytes__

JWT_ISSUER=DAMA_Software_Staging
JWT_PRIVATE_KEY_B64=__staging_unique_priv_pem_b64__
JWT_PUBLIC_KEY_B64=__staging_unique_pub_pem_b64__

RABBITMQ_USER=dama
RABBITMQ_PASSWORD=__set_strong_password__
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
