{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://*:80",
        "Protocols": "Http1"
      },
      "Grpc": {
        "Url": "https://*:81",
        "Protocols": "Http2",
        "Certificate": {
          "Path": "/etc/dama/tls/server.crt",
          "KeyPath": "/etc/dama/tls/server.key"
        }
      }
    }
  }
}
