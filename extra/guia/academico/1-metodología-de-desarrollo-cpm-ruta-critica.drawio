        <mxCell id="title" value="DAMA — Red de actividades (Actividad-en-Nodo) y Ruta Crítica (CPM)&#10;Unidad: semanas · TPT = 26 semanas · Rutas críticas (holgura 0) resaltadas en rojo" style="text;html=1;align=center;verticalAlign=middle;fontSize=16;fontStyle=1;whiteSpace=wrap;" vertex="1" parent="1">
